    def apply_text_transform(self, transform, command_name="Text Transform"):
        b = self.text.get_buffer()
        start, end = self.selected_or_all_range()
        old = b.get_text(b.get_iter_at_offset(start), b.get_iter_at_offset(end), True)
        current = self.buffer_text()
        use_layer_uppercase = (
            command_name in {"Uppercase", "Upper Case", "UPPERCASE"}
            or transform is str.upper
        )
        use_layer_lowercase = (
            command_name in {"Lowercase", "Lower Case", "LOWERCASE"}
            or transform is str.lower
        )
        use_layer_smart_typography = (
            command_name == "Smart Typography"
            or transform is smart_typography
        )
        use_layer_reflow_paragraph = (
            command_name == "Reflow Paragraph"
        )
        use_layer_clean_pdf = (
            command_name in {"Clean PDF Text", "Clean Selected Text from PDF"}
            or transform is clean_pdf_text
        )
        use_layer_remove_extra_spaces = (
            command_name == "Remove Extra Spaces"
            or transform is remove_extra_spaces
        )
        use_layer_join_lines = (
            command_name == "Join Lines"
            or transform is join_lines
        )
        use_layer_remove_trailing_spaces = (
            command_name == "Remove Trailing Spaces"
            or transform is remove_trailing_spaces
        )
        use_layer_title_case = (
            command_name == "Title Case"
            or transform is title_case
        )
        use_layer_sort_lines = (
            command_name in {"Sort A-Z", "Sort Z-A"}
        )
        use_layer_sentence_case = (
            command_name == "Sentence Case"
            or transform is sentence_case
        )
        if use_layer_uppercase:
            new, changed = self.command_layer_uppercase_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_lowercase:
            new, changed = self.command_layer_lowercase_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_smart_typography:
            new, changed = self.command_layer_smart_typography_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_reflow_paragraph:
            new, changed = self.command_layer_reflow_paragraph_text(old, width=80)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_clean_pdf:
            new, changed = self.command_layer_clean_pdf_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_remove_extra_spaces:
            new, changed = self.command_layer_remove_extra_spaces_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_join_lines:
            new, changed = self.command_layer_join_lines_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_remove_trailing_spaces:
            new, changed = self.command_layer_remove_trailing_spaces_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_title_case:
            new, changed = self.command_layer_title_case_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_sort_lines:
            new, changed = self.command_layer_sort_lines_text(
                old, reverse=(command_name == "Sort Z-A")
            )
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        elif use_layer_sentence_case:
            new, changed = self.command_layer_sentence_case_text(old)
            if not changed:
                return False
            _, select = command_transform_range(current, start, end, lambda _text: new)
        else:
            _, select = command_transform_range(current, start, end, transform)
            new = transform(old)
        def edit(buf):
            it1 = buf.get_iter_at_offset(start)
            it2 = buf.get_iter_at_offset(end)
            buf.delete(it1, it2)
            buf.insert(buf.get_iter_at_offset(start), new)
        return self.execute_command(command_name, edit, select_range=select)

    def on_uppercase(self, *_):
        return self.replace_selection(str.upper, "Uppercase")

    def on_lowercase(self, *_):
        return self.replace_selection(str.lower, "Lowercase")

    def on_smart_typography(self, *_):
        return self.apply_text_transform(smart_typography, "Smart Typography")

    def on_reflow_paragraph(self, *_):
        return self.apply_text_transform(lambda t: reflow_paragraph(t, width=80), "Reflow Paragraph")

    def on_clean_selected_pdf(self, *_):
        return self.apply_text_transform(clean_pdf_text, "Clean PDF Text")

    def on_remove_extra_spaces(self, *_):
        return self.apply_text_transform(remove_extra_spaces, "Remove Extra Spaces")

    def on_join_lines(self, *_):
        return self.apply_text_transform(join_lines, "Join Lines")

    def on_remove_trailing_spaces(self, *_):
        return self.apply_text_transform(remove_trailing_spaces, "Remove Trailing Spaces")

    def on_title_case(self, *_):
        return self.apply_text_transform(title_case, "Title Case")

    def on_sentence_case(self, *_):
        return self.apply_text_transform(sentence_case, "Sentence Case")

    def on_sort_lines_ascending(self, *_):
        return self.apply_text_transform(lambda t: sort_lines(t, reverse=False), "Sort A-Z")

    def on_sort_lines_descending(self, *_):
        return self.apply_text_transform(lambda t: sort_lines(t, reverse=True), "Sort Z-A")

    def _clipboard(self):
        return Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)

    def on_cut(self, *_):
        self.text.get_buffer().cut_clipboard(self._clipboard(), True)

    def on_copy(self, *_):
        self.text.get_buffer().copy_clipboard(self._clipboard())

    def on_paste(self, *_):
        self.text.get_buffer().paste_clipboard(self._clipboard(), None, True)

    def on_select_all(self, *_):
        buf = self.text.get_buffer()
        start, end = buf.get_bounds()
        buf.select_range(start, end)

    def on_paste_clean_pdf(self, *_):
        clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        text = clipboard.wait_for_text()
        if text is None:
            return
        cleaned = clean_pdf_text(text)
        b = self.text.get_buffer()
        cursor = b.get_iter_at_mark(b.get_insert()).get_offset()
        selection = None
        if b.get_has_selection():
            s, e = b.get_selection_bounds()
            selection = (s.get_offset(), e.get_offset())
        start, end, insertion, select_range = command_paste_text_plan(
            self.buffer_text(),
            cleaned,
            cursor,
            selection=selection,
        )
        def edit(buf):
            it1 = buf.get_iter_at_offset(start)
            it2 = buf.get_iter_at_offset(end)
            buf.delete(it1, it2)
            buf.insert(buf.get_iter_at_offset(start), insertion)
        self.execute_command("Paste Clean PDF", edit, select_range=select_range)

    def on_paste_plain_text(self, *_):
        clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        text = clipboard.wait_for_text()
        if text is None:
            return
        b = self.text.get_buffer()
        cursor = b.get_iter_at_mark(b.get_insert()).get_offset()
        selection = None
        if b.get_has_selection():
            s, e = b.get_selection_bounds()
            selection = (s.get_offset(), e.get_offset())
        start, end, insertion, _inserted_range = command_paste_text_plan(
            self.buffer_text(),
            text,
            cursor,
            selection=selection,
        )
        caret = start + len(insertion)
        def edit(buf):
            it1 = buf.get_iter_at_offset(start)
            it2 = buf.get_iter_at_offset(end)
            buf.delete(it1, it2)
            buf.insert(buf.get_iter_at_offset(start), insertion)
        return self.execute_command(
            "Paste Plain Text",
            edit,
            select_range=(caret, caret),
        )

    def on_duplicate_line_or_selection(self, *_):
        b = self.text.get_buffer()
        selection = None
        if b.get_has_selection():
            s, e = b.get_selection_bounds()
            selection = (s.get_offset(), e.get_offset())
        plan = command_duplicate_line_or_selection_plan(
            self.buffer_text(),
            self.get_cursor_offset(),
            selection=selection,
        )
        if plan is None:
            return
        insert_pos, insertion, select_range, duplicates_selection = plan
        def edit(buf):
            buf.insert(buf.get_iter_at_offset(insert_pos), insertion)
        action_name = "Duplicate Selection" if duplicates_selection else "Duplicate Line"
        return self.execute_command(action_name, edit, select_range=select_range)

    def on_move_line(self, direction):
        text = self.buffer_text()
        if not text:
            return
        cursor = self.get_cursor_offset()
        lines = text.splitlines(True)
        if not lines:
            return
        offsets = []
        pos = 0
        for line in lines:
            offsets.append(pos)
            pos += len(line)
        idx = 0
        for i, start in enumerate(offsets):
            end = start + len(lines[i])
            if start <= cursor < end or (i == len(lines) - 1 and cursor == end):
                idx = i
                break
        new_idx = idx + int(direction)
        if new_idx < 0 or new_idx >= len(lines):
            return
        col = max(0, cursor - offsets[idx])
        moved_line_len = len(lines[idx])
        lines[idx], lines[new_idx] = lines[new_idx], lines[idx]
        new_text = "".join(lines)
        new_offsets = []
        pos = 0
        for line in lines:
            new_offsets.append(pos)
            pos += len(line)
        new_cursor = min(new_offsets[new_idx] + col, new_offsets[new_idx] + moved_line_len)
        def edit(buf):
            buf.set_text(new_text)
        self.execute_command("Move Line", edit, select_range=(new_cursor, new_cursor))

    def on_trim_trailing_on_save(self, item):
        self.trim_trailing_on_save = item.get_active()
        self.save_settings()

    def on_document_statistics(self, *_):
        text_before_statistics = self.buffer_text()
        result = self.command_layer.dispatch(
            "writing.statistics",
            CommandContext(app=self, source="gui", data={"text": text_before_statistics}),
        )
        if result.success and isinstance(result.value, dict) and "statistics" in result.value:
            stats = result.value["statistics"]
        else:
            stats = document_statistics(text_before_statistics)
        msg = (
            f"Words: {stats['words']}\n"
            f"Characters: {stats['characters']}\n"
            f"Characters without spaces: {stats['characters_no_spaces']}\n"
            f"Paragraphs: {stats['paragraphs']}\n"
            f"Lines: {stats['lines']}\n"
            f"Estimated reading time: {stats['reading_minutes']} min"
        )
        self.large_info("Document Statistics", msg)

    def populate_template_menu(self):
        if not hasattr(self, "template_menu"):
            return
        for child in list(self.template_menu.get_children()):
            self.template_menu.remove(child)
        templates = list_templates(self.state.config_dir)
        if not templates:
            item = Gtk.MenuItem(label="No templates")
            item.set_sensitive(False)
            self.template_menu.append(item)
        else:
            for name, path in templates:
                item = Gtk.MenuItem(label=name)
                item.connect("activate", lambda _w, p=path: self.on_new_from_template(p))
                self.template_menu.append(item)
        self.template_menu.show_all()

    def on_new_from_template(self, path):
        if not self.may_continue():
            return
        try:
            self.current_file = None
            self.set_buffer(read_template(path))
            self.modified = False
            self.update_title()
        except OSError as e:
            self.error(str(e))


    def on_word_wrap(self, item):
        self.word_wrap = item.get_active()
        self.apply_wrap_policy()
        self.save_settings()
        self.update_title()

    def toggle_word_wrap(self, *_):
        if hasattr(self, "word_wrap_item"):
            self.word_wrap_item.set_active(not self.word_wrap_item.get_active())

    def on_transparent_mode(self, item):
        if item.get_active():
            self.set_opacity_value(int(self.settings.get("opacity", DEFAULT_OPACITY)) if int(self.settings.get("opacity", DEFAULT_OPACITY)) < 100 else DEFAULT_OPACITY)
        else:
            self.set_opacity_value(100)

    def toggle_transparent_mode(self, *_):
        if hasattr(self, "transparent_item"):
            self.transparent_item.set_active(not self.transparent_item.get_active())

    def toggle_always_on_top(self, *_):
        if hasattr(self, "always_item"):
            self.always_item.set_active(not self.always_item.get_active())

    def toggle_line_numbers(self, *_):
        if hasattr(self, "line_item"):
            self.line_item.set_active(not self.line_item.get_active())

    def on_font(self, *_):
        d = Gtk.FontChooserDialog(title="Font", transient_for=self)
        d.set_font(f"{self.font_family} {self.font_size}")
        if d.run() == Gtk.ResponseType.OK:
            desc = Pango.FontDescription(d.get_font())
            family = desc.get_family()
            size = desc.get_size() // Pango.SCALE if desc.get_size() > 0 else self.font_size
            if family:
                self.font_family = family
            if size:
                self.font_size = max(MIN_FONT, min(MAX_FONT, int(size)))
            self.apply_font()
            self.save_settings()
        d.destroy()

    def command_layer_insert_date_time_text(self, now, fmt="%Y-%m-%d %H:%M"):
        # Format an explicit moment through CommandLayer without touching the editor buffer.
        result = self.command_layer.dispatch(
            "writing.insert-date-time",
            CommandContext(
                app=self,
                source="gui",
                data={"now": now, "format": fmt},
            ),
        )
        if not result.success or not isinstance(result.value, dict):
            return "", False
        insertion = result.value.get("text", "")
        if not isinstance(insertion, str):
            return "", False
        return insertion, bool(insertion)

    def on_insert_datetime(self, *_):
        txt, changed = self.command_layer_insert_date_time_text(datetime.now())
        if not changed:
            return False
        cursor = self.get_cursor_offset()
        _, select = command_insert_at(self.buffer_text(), cursor, txt)
        def edit(buf):
            buf.insert_at_cursor(txt)
        return self.execute_command("Insert Date/Time", edit, select_range=select)

    def on_replace_all_dialog(self, *_):
        self.on_find_replace()

    def load_favourite_store(self):
        return self.state.load_favourite_store(limit=50)

    def load_favourites(self):
        return self.state.load_favourites(limit=50)

    def save_favourites(self, items):
        return self.state.save_favourites(items, limit=50)

    def populate_favourites_menu(self):
        if not hasattr(self, "favourites_menu"):
            return ()

        current_children = list(self.favourites_menu.get_children())
        for child in getattr(self, "_favourite_dynamic_items", ()):
            if child in current_children:
                self.favourites_menu.remove(child)

        items = self.load_favourites()
        dynamic_items = []
        if not items:
            item = Gtk.MenuItem(label="No favourites")
            item.set_sensitive(False)
            self.favourites_menu.append(item)
            dynamic_items.append(item)
        else:
            for path in items:
                label = os.path.basename(path) or path
                item = Gtk.MenuItem(label=label)
                item.set_tooltip_text(path)
                item.connect("activate", lambda _w, p=path: self.open_favourite_path(p))
                self.favourites_menu.append(item)
                dynamic_items.append(item)

        self._favourite_dynamic_items = dynamic_items
        self.favourites_menu.show_all()
        return tuple(items)

    def open_favourite_path(self, path):
        if not self.may_continue():
            return False
        plan = prepare_open_favorite_plan(
            path,
            path_is_file=os.path.isfile(path),
        )
        if not plan.should_open:
            self.error("Favourite file not found or is not a regular file:\n" + path)
            return False
        return self.open_path(plan.target_path)

    def on_add_favourite(self, *_):
        if not self.current_file:
            self.error("Save the current document before adding it to Favourites.")
            return False
        plan = prepare_add_favorite_plan(
            os.path.abspath(self.current_file),
            self.load_favourite_store(),
        )
        if not self.save_favourites(list(plan.updated_paths)):
            self.error("Could not add file to Favourites.")
            return False
        self.populate_favourites_menu()
        self.info("Added to Favourites:\n" + plan.favorite_path)
        return True

    def apply_favourite_edits(self, text):
        submitted = parse_favorite_edit_text(text)
        resolved = []
        for item in submitted:
            path = os.path.abspath(os.path.expanduser(item))
            resolved.append((path, os.path.isfile(path)))
        plan = prepare_edit_favorite_plan(
            self.load_favourite_store(),
            resolved,
        )
        if not self.save_favourites(list(plan.updated_paths)):
            self.error("Could not save Favourites.")
            return False
        self.populate_favourites_menu()
        if plan.rejected_paths:
            self.error(
                "These favourite entries are not regular files and were skipped:\n"
                + "\n".join(plan.rejected_paths[:10])
            )
        return True

    def on_edit_favourites(self, *_):
        d = Gtk.Dialog(title="Edit Favourites", transient_for=self, modal=True)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Save", Gtk.ResponseType.OK)
        box = d.get_content_area()
        box.set_spacing(8)
        box.set_margin_start(10)
        box.set_margin_end(10)
        box.set_margin_top(10)
        box.set_margin_bottom(10)
        label = Gtk.Label(label="One file path per line:")
        label.set_xalign(0)
        view = Gtk.TextView()
        view.set_wrap_mode(Gtk.WrapMode.NONE)
        view.get_buffer().set_text("\n".join(self.load_favourite_store()))
        scroll = Gtk.ScrolledWindow()
        scroll.set_size_request(520, 260)
        scroll.add(view)
        box.pack_start(label, False, False, 0)
        box.pack_start(scroll, True, True, 0)
        d.show_all()
        result = False
        if d.run() == Gtk.ResponseType.OK:
            b = view.get_buffer()
            s, e = b.get_bounds()
            result = self.apply_favourite_edits(b.get_text(s, e, True))
        d.destroy()
        return result

    def on_reload_favourites(self, *_):
        self.populate_favourites_menu()
        return True

    def text_stats(self):
        text = self.buffer_text()
        stats = document_statistics(text)
        _old_words, chars, lines = calc_text_stats(text)
        return stats["words"], chars, lines

    def schedule_status_update(self):
        if self.word_count_source:
            return
        def run():
            self.word_count_source = None
            self.update_title()
            return False
        self.word_count_source = GLib.timeout_add(250, run)

    def update_line_numbers(self):
        if not hasattr(self, "line_numbers"):
            return
        if not self.show_line_numbers:
            self.line_numbers.set_text("")
            return
        _words, _chars, lines = self.text_stats()
        self.line_numbers.set_text("\n".join(str(i) for i in range(1, lines + 1)))
        # Compact dynamic gutter: enough for digit count, never a wide sidebar.
        try:
            digits = max(1, len(str(max(1, lines))))
            width = max(LINE_GUTTER_MIN_WIDTH, min(LINE_GUTTER_MAX_WIDTH, 12 + digits * 9))
            parent = self.line_numbers.get_parent()
            if parent is not None:
                parent.set_size_request(width, 1)
            self.line_numbers.set_size_request(max(1, width - 5), 1)
        except Exception as exc:
            log_nonfatal("line-number gutter resize failed", exc)

    def load_recent_files(self):
        return self.state.load_recent_files(limit=10)

    def save_recent_files(self, items):
        return self.state.save_recent_files(items, limit=10)

    def add_recent_file(self, path):
        if not path:
            return
        self.state.add_recent_file(path, limit=10)
        if hasattr(self, "recent_menu"):
            self.populate_recent_menu()

    def populate_recent_menu(self):
        if not hasattr(self, "recent_menu"):
            return
        for child in list(self.recent_menu.get_children()):
            self.recent_menu.remove(child)
        items = self.load_recent_files()
        if not items:
            item = Gtk.MenuItem(label="No recent files")
            item.set_sensitive(False)
            self.recent_menu.append(item)
        else:
            for path in items:
                label = os.path.basename(path) or path
                item = Gtk.MenuItem(label=label)
                item.set_tooltip_text(path)
                item.connect("activate", lambda _w, p=path: self.open_recent_path(p))
                self.recent_menu.append(item)
            self.sep(self.recent_menu)
            self.item(self.recent_menu, "Clear Recent Files", self.on_clear_recent)
        self.recent_menu.show_all()

    def open_recent_path(self, path):
        if not self.may_continue():
            return False
        plan = prepare_open_recent_plan(
            path,
            self.load_recent_files(),
            path_exists=os.path.exists(path),
        )
        if plan.should_open and self.open_path(path):
            return True
        if not plan.should_open:
            self.error("Recent file not found:\n" + path)
        self.save_recent_files(list(plan.remaining_paths_after_failure))
        self.populate_recent_menu()
        return False

    def on_clear_recent(self, *_):
        plan = prepare_clear_recent_plan(self.load_recent_files())
        if not plan.should_clear:
            return False
        if not self.save_recent_files(list(plan.remaining_paths)):
            self.error("Could not clear recent files.")
            return False
        self.populate_recent_menu()
        return True

    def clear_search_highlights(self):
        if not hasattr(self, "search_tag"):
            return
        b = self.text.get_buffer()
        s, e = b.get_bounds()
        b.remove_tag(self.search_tag, s, e)

    def schedule_search_highlight(self):
        if not self.last_search:
            return
        if self.search_highlight_source:
            return
        def run():
            self.search_highlight_source = None
            self.highlight_all_search(self.last_search)
            return False
        self.search_highlight_source = GLib.timeout_add(300, run)

    def on_character_map(self, *_):
        d = Gtk.Dialog(title="Character Map", transient_for=self, modal=True)
        d.set_name("calamus-character-map-dialog")
        d.add_buttons("Close", Gtk.ResponseType.CLOSE)
        d.set_default_size(720, 520)

        css = b"""
        #calamus-character-map-dialog,
        #calamus-character-map-dialog box,
        #calamus-character-map-dialog scrolledwindow,
        #calamus-character-map-dialog viewport {
            background-color: #ffffff;
            color: #000000;
            background-image: none;
        }
        #calamus-character-map-dialog label {
            color: #000000;
        }
        #calamus-character-map-dialog button,
        #calamus-character-map-dialog button label {
            background-color: #eeeeee;
            color: #000000;
            background-image: none;
            text-shadow: none;
            box-shadow: none;
        }
        #calamus-character-map-dialog button:hover {
            background-color: #dddddd;
            color: #000000;
            background-image: none;
        }
        """
        provider = Gtk.CssProvider()
        provider.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        box = d.get_content_area()
        box.set_spacing(8)
        box.set_margin_start(10)
        box.set_margin_end(10)
        box.set_margin_top(10)
        box.set_margin_bottom(10)

        hint = Gtk.Label(label="Click a character to insert it at the cursor position. Shortcut: Ctrl+Alt+F10")
        hint.set_xalign(0)
        box.pack_start(hint, False, False, 0)

        notebook = Gtk.Notebook()
        box.pack_start(notebook, True, True, 0)

        groups = [
            ("Alphabet", "ABCDEFGHIJKLMNOPQRSTUVWXYZ\nabcdefghijklmnopqrstuvwxyz"),
            ("Accents", "ÀÁÂÃÄÅÆÇÈÉÊËÌÍÎÏÐÑÒÓÔÕÖØÙÚÛÜÝÞß\nàáâãäåæçèéêëìíîïðñòóôõöøùúûüýþÿ\nĀāĂăĄąĆćĈĉĊċČčĎďĐđĒēĔĕĖėĘęĚěĞğĠġĢģĪīĮįİıŁłŃńŇňŐőŒœŔŕŘřŚśŞşŠšŤťŪūŮůŰűŲųŸŹźŻżŽž"),
            ("Greek", "ΑΒΓΔΕΖΗΘΙΚΛΜΝΞΟΠΡΣΤΥΦΧΨΩ\nαβγδεζηθικλμνξοπρστυφχψω"),
            ("Numbers", "0123456789 ⁰¹²³⁴⁵⁶⁷⁸⁹ ₀₁₂₃₄₅₆₇₈₉ ½⅓⅔¼¾⅛⅜⅝⅞"),
            ("Punctuation", ".,;:!?¡¿'\"`´‘’“”‚„…·•-–—_()[]{}<>/\\|@#&§¶"),
            ("Math", "+−×÷=≠≈≡<≤>≥±∞√∑∏∫∂∆∇πµΩ°′″‰%¬∧∨∩∪⊂⊃⊆⊇∈∉∅"),
            ("Currency", "€£$¥¢₹₽₩₪₫₴₦₱₲₵₡₭₮₨฿"),
            ("Arrows", "←↑→↓↔↕↖↗↘↙⇐⇑⇒⇓⇔⇧⇨➜➤➔➜➞"),
            ("Symbols", "©®™✓✔✕✖★☆♥♦♣♠♪♫☀☁☂☃☎☑☐☒⚠⚙⚡☕⌘⌥⇧⎋"),
        ]

        def insert_char(ch):
            b = self.text.get_buffer()
            if b.get_has_selection():
                self.replace_selection(lambda _old, c=ch: c)
                return
            cursor = b.get_iter_at_mark(b.get_insert()).get_offset()
            def edit(buf):
                buf.insert(buf.get_iter_at_offset(cursor), ch)
            self.execute_command("Insert Character", edit, select_range=(cursor + len(ch), cursor + len(ch)))

        for title, chars in groups:
            scroll = Gtk.ScrolledWindow()
            scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
            grid = Gtk.Grid(column_spacing=4, row_spacing=4)
            grid.set_margin_start(8)
            grid.set_margin_end(8)
            grid.set_margin_top(8)
            grid.set_margin_bottom(8)
            scroll.add(grid)

            row = 0
            col = 0
            for ch in chars:
                if ch == "\n":
                    row += 1
                    col = 0
                    continue
                if ch == " ":
                    continue
                btn = Gtk.Button(label=ch)
                btn.set_size_request(34, 30)
                btn.set_tooltip_text("Insert " + ch)
                btn.connect("clicked", lambda _b, c=ch: insert_char(c))
                grid.attach(btn, col, row, 1, 1)
                col += 1
                if col >= 16:
                    row += 1
                    col = 0
            notebook.append_page(scroll, Gtk.Label(label=title))

        d.show_all()
        d.run()
        d.destroy()


    def build_clip_collection(self):
        self.clips = self.state.load_clips()
        # Regression invariant: equivalent to
        # self.clip_list.connect("button-press-event", self.on_clip_list_button_press)
        self.clip_panel, self.clip_list = build_clip_panel(
            self.on_clip_list_button_press,
            self.on_clip_add_selection,
            self.on_clip_insert,
            self.on_clip_delete,
        )
        self.refresh_clip_list()

    def refresh_clip_list(self):
        if not hasattr(self, "clip_list"):
            return
        for child in list(self.clip_list.get_children()):
            self.clip_list.remove(child)
        for clip in self.clips:
            row = Gtk.ListBoxRow()
            label = Gtk.Label(label=clip.get("title", "Clip"))
            label.set_xalign(0)
            label.set_margin_top(4)
            label.set_margin_bottom(4)
            row.add(label)
            self.clip_list.add(row)
        self.clip_list.show_all()

    def toggle_clip_collection(self, *_):
        if getattr(self, "clip_panel_attached", False):
            try:
                self.body_paned.remove(self.clip_panel)
            except Exception:
                self.clip_panel.hide()
            self.clip_panel_attached = False
            self.queue_wrap_reflow()
            return

        # Attach the panel only when requested.  This is more reliable than
        # hiding a Gtk.Paned child with no_show_all, which can fail to remap on
        # some GTK/theme combinations.
        if self.clip_panel.get_parent() is None:
            self.body_paned.pack2(self.clip_panel, False, False)
        self.clip_panel_attached = True
        self.clip_panel.show_all()
        alloc = self.body_paned.get_allocation()
        width = getattr(alloc, "width", 900) or 900
        panel_width = calculate_clip_panel_width(width)
        self.clip_panel.set_size_request(panel_width, -1)
        self.clip_panel.set_hexpand(False)
        self.clip_panel.set_vexpand(True)
        self.body_paned.set_position(max(1, width - panel_width))
        self.queue_wrap_reflow()

    def selected_clip_index(self):
        row = self.clip_list.get_selected_row() if hasattr(self, "clip_list") else None
        return row.get_index() if row is not None else None

    def on_clip_list_button_press(self, listbox, event):
        """Insert the clicked clip on a primary-button double click only.

        This intentionally avoids Gtk.ListBox row-activated because GTK also
        emits that signal for keyboard activation.  Enter should keep its
        normal list/navigation semantics and must not insert a clip.
        """
        if event.type != Gdk.EventType._2BUTTON_PRESS or getattr(event, "button", 0) != 1:
            return False
        row = listbox.get_row_at_y(int(event.y))
        if row is None:
            return False
        listbox.select_row(row)
        self.text.grab_focus()
        self.on_clip_insert()
        return True

    def insert_clip_number(self, number):
        try:
            idx = int(number) - 1
        except (TypeError, ValueError):
            return
        if idx < 0 or idx >= len(self.clips):
            return
        if hasattr(self, "clip_list"):
            row = self.clip_list.get_row_at_index(idx)
            if row is not None:
                self.clip_list.select_row(row)
        self.on_clip_insert()

    def on_clip_add_selection(self, *_):
        b = self.text.get_buffer()
        if b.get_has_selection():
            s, e = b.get_selection_bounds()
            txt = b.get_text(s, e, True)
        else:
            txt = ""
        self.clips.insert(0, new_clip(clip_title_from_text(txt), txt))
        self.state.save_clips(self.clips)
        self.refresh_clip_list()

    def on_clip_insert(self, *_):
        idx = self.selected_clip_index()
        if idx is None or idx < 0 or idx >= len(self.clips):
            return
        txt = self.clips[idx].get("text", "")
        def edit(buf):
            buf.insert_at_cursor(txt)
        self.execute_command("Insert Clip", edit)

    def on_clip_delete(self, *_):
        idx = self.selected_clip_index()
        if idx is None or idx < 0 or idx >= len(self.clips):
            return
        del self.clips[idx]
        self.state.save_clips(self.clips)
        self.refresh_clip_list()

    def toggle_focus_mode(self, *_):
        self.focus_mode = not self.focus_mode
        self.text.set_left_margin(42 if self.focus_mode else 10)
        self.text.set_right_margin(42 if self.focus_mode else 10)
        self.update_title()

    def toggle_distraction_free(self, *_):
        self.distraction_free = not self.distraction_free
        if self.distraction_free:
            self.fullscreen()
            self.menubar.hide()
            self.status.hide()
        else:
            self.unfullscreen()
            self.menubar.show()
            self.status.show()

    def toggle_current_line_highlight(self, *_):
        self.current_line_highlight = not self.current_line_highlight
        self.update_current_line_highlight()

    def update_current_line_highlight(self):
        if not hasattr(self, "current_line_tag"):
            return
        b = self.text.get_buffer()
        s, e = b.get_bounds()
        b.remove_tag(self.current_line_tag, s, e)
        if not self.current_line_highlight:
            return
        cur = b.get_iter_at_mark(b.get_insert())
        start = cur.copy()
        start.set_line_offset(0)
        end = start.copy()
        if not end.ends_line():
            end.forward_to_line_end()
        b.apply_tag(self.current_line_tag, start, end)

    def toggle_bookmark(self, *_):
        off = self.get_cursor_offset()
        if off in self.bookmarks:
            self.bookmarks.remove(off)
            self.status.set_text("Bookmark removed")
        else:
            self.bookmarks.append(off)
            self.bookmarks.sort()
            self.status.set_text("Bookmark added")

    def next_bookmark(self, *_):
        if not self.bookmarks:
            return
        cur = self.get_cursor_offset()
        target = next((x for x in self.bookmarks if x > cur), self.bookmarks[0])
        self.set_cursor_offset(target)

    def previous_bookmark(self, *_):
        if not self.bookmarks:
            return
        cur = self.get_cursor_offset()
        prior = [x for x in self.bookmarks if x < cur]
        target = prior[-1] if prior else self.bookmarks[-1]
        self.set_cursor_offset(target)

    def on_manage_bookmarks(self, *_):
        if not self.bookmarks:
            self.info("No bookmarks have been inserted. Use Revise > Insert Bookmark Here or Ctrl+F2.")
            return
        lines = []
        text = self.buffer_text()
        for i, off in enumerate(self.bookmarks, start=1):
            line = text.count("\n", 0, max(0, min(off, len(text)))) + 1
            lines.append(f"{i}. Line {line} — offset {off}")
        self.large_info("Bookmarks", "\n".join(lines))

    def on_go_to_line(self, *_):
        _words, _chars, total_lines = self.text_stats()
        line_no, invalid = prompt_go_to_line(self, total_lines)
        if invalid:
            self.error("Invalid line number.")
            return
        if line_no is None:
            return
        b = self.text.get_buffer()
        target_line = line_to_buffer_index(line_no, b.get_line_count())
        it = b.get_iter_at_line_offset(target_line, 0)
        b.place_cursor(it)
        self.text.grab_focus()

        def reveal():
            try:
                mark = b.get_insert()
                self.text.scroll_to_mark(mark, 0.08, True, 0.0, 0.15)
            except Exception as exc:
                log_nonfatal("go-to-line scroll failed", exc)
            return False

        GLib.idle_add(reveal)

    def on_find_replace(self, *_):
        def highlight(needle, match_case, whole_word):
            self.last_search = needle
            return self.highlight_all_search(needle, match_case=match_case, whole_word=whole_word)

        callbacks = {
            "highlight": highlight,
            "find": lambda needle, backwards, match_case, whole_word, wrap: self.find_text(needle, backwards=backwards, match_case=match_case, whole_word=whole_word, wrap=wrap),
            "need_current_match": lambda needle: (not self.last_match) or self.last_search != needle,
            "replace_current": lambda needle, repl, match_case, whole_word: self.replace_current_match(needle, repl, match_case=match_case, whole_word=whole_word),
            "replace_all": lambda needle, repl, match_case, whole_word: self.replace_all_literal(needle, repl, match_case=match_case, whole_word=whole_word),
        }
        run_find_replace_dialog(self, self.last_search, callbacks)

    def on_find_next(self, *_):
        if not can_repeat_search(self.last_search):
            self.on_find_replace()
            return
        self.highlight_all_search(self.last_search)
        if not self.find_text(self.last_search):
            self.info("No match found.")

    def on_find_previous(self, *_):
        if not can_repeat_search(self.last_search):
            self.on_find_replace()
            return
        self.highlight_all_search(self.last_search)
        if not self.find_text(self.last_search, backwards=True):
            self.info("No previous match found.")

    def search_matches(self, needle, match_case=False, whole_word=False):
        return calc_search_matches(self.buffer_text(), needle, match_case=match_case, whole_word=whole_word)

    def highlight_all_search(self, needle, match_case=False, whole_word=False):
        self.clear_search_highlights()
        matches = self.search_matches(needle, match_case=match_case, whole_word=whole_word)
        if not matches:
            return 0
        b = self.text.get_buffer()
        for m in matches:
            it1 = b.get_iter_at_offset(m.start())
            it2 = b.get_iter_at_offset(m.end())
            b.apply_tag(self.search_tag, it1, it2)
        return len(matches)

    def find_text(self, needle, backwards=False, match_case=False, whole_word=False, wrap=True):
        matches = self.search_matches(needle, match_case=match_case, whole_word=whole_word)
        if not matches:
            self.last_match = None
            return False
        b = self.text.get_buffer()
        if b.get_has_selection():
            s, e = b.get_selection_bounds()
            cursor = s.get_offset() if backwards else e.get_offset()
        else:
            cursor = b.get_iter_at_mark(b.get_insert()).get_offset()
        chosen = choose_search_match(matches, cursor, backwards=backwards, wrap=wrap)
        if chosen is None:
            self.last_match = None
            return False
        self.last_search = needle
        self.last_match = (chosen.start(), chosen.end())
        self.select_range(chosen.start(), chosen.end())
        return True

    def find_text_previous(self, needle):
        return self.find_text(needle, backwards=True)

    def replace_current_match(self, needle, replacement, match_case=False, whole_word=False):
        plan = prepare_current_replacement(
            self.buffer_text(),
            needle,
            replacement,
            self.last_match,
            match_case=match_case,
            whole_word=whole_word,
        )
        if plan is None:
            return False
        start, end, replacement, next_match = plan
        self.replace_buffer_range(start, end, replacement)
        self.last_match = next_match
        return True

    def replace_all_literal(self, old, new, match_case=False, whole_word=False):
        text = self.buffer_text()
        replaced, count = prepare_replace_all_plan(
            text, old, new, match_case=match_case, whole_word=whole_word
        )
        if not count or replaced == text:
            return 0
        def edit(buf):
            s, e = buf.get_bounds()
            buf.delete(s, e)
            buf.insert(buf.get_start_iter(), replaced)
        self.execute_command("Replace All", edit)
        self.last_match = None
        return count

    def on_print_preview(self, *_):
        op = Gtk.PrintOperation()
        op.set_job_name("Calamus")
        op.connect("begin-print", self.on_begin_print)
        op.connect("draw-page", self.on_draw_page)
        try:
            op.run(Gtk.PrintOperationAction.PREVIEW, self)
        except Exception as e:
            self.error(str(e))

    def on_print(self, *_):
        op = Gtk.PrintOperation()
        op.set_job_name("Calamus")
        op.connect("begin-print", self.on_begin_print)
        op.connect("draw-page", self.on_draw_page)
        try:
            op.run(Gtk.PrintOperationAction.PRINT_DIALOG, self)
        except Exception as e:
            self.error(str(e))

    def on_begin_print(self, operation, context):
        text = self.buffer_text()
        lines = text.splitlines() or [""]
        # Conservative pagination for lightweight, dependency-free printing.
        # GTK/Pango renders the actual page; this just decides page chunks.
        lines_per_page = 54
        self.print_pages = ["\n".join(lines[i:i+lines_per_page]) for i in range(0, len(lines), lines_per_page)] or [""]
        operation.set_n_pages(len(self.print_pages))

    def on_draw_page(self, operation, context, page_nr):
        cr = context.get_cairo_context()
        layout = context.create_pango_layout()
        layout.set_text(self.print_pages[page_nr], -1)
        desc = Pango.FontDescription(f"{self.font_family} {self.font_size}")
        layout.set_font_description(desc)
        layout.set_width(int(context.get_width() * Pango.SCALE))
        cr.move_to(0, 0)
        PangoCairo.show_layout(cr, layout)

    def on_lang(self, item, lang):
        if item.get_active():
            self.spell_lang = lang
            self.save_settings()
            self.update_title()

    def clear_spell_tags(self):
        b = self.text.get_buffer()
        s, e = b.get_bounds()
        b.remove_tag(self.tag, s, e)

    def hunspell_dict(self):
        return spell_hunspell_dict(self.spell_lang)

    def hunspell_base_command(self):
        return spell_hunspell_base_command(self.spell_lang)

    def hunspell_misspelled_words(self, text):
        return spell_hunspell_misspelled_words(text, self.spell_lang)

    def hunspell_suggestions(self, word):
        return spell_hunspell_suggestions(word, self.spell_lang)

    def find_next_error(self, start_offset, misspelled):
        text = self.buffer_text()
        for m in WORD_RE.finditer(text, max(0, start_offset)):
            word = m.group(0)
            if word in misspelled:
                return m.start(), m.end(), word
        return None

    def select_range(self, start, end):
        b = self.text.get_buffer()
        it1 = b.get_iter_at_offset(start)
        it2 = b.get_iter_at_offset(end)
        b.select_range(it1, it2)
        self.text.scroll_to_iter(it1, 0.15, False, 0, 0)

    def spelling_dialog(self, word, suggestions):
        return run_spelling_dialog(self, word, suggestions)

    def replace_buffer_range(self, start, end, replacement):
        def edit(buf):
            it1 = buf.get_iter_at_offset(start)
            it2 = buf.get_iter_at_offset(end)
            buf.delete(it1, it2)
            buf.insert(buf.get_iter_at_offset(start), replacement)
        self.execute_command("Replace Selection", edit, select_range=(start, start + len(replacement)))

    def replace_all_word(self, old, new, from_offset=0):
        text = self.buffer_text()
        pattern = re.compile(r"(?<![A-Za-zÀ-ÖØ-öø-ÿ'])" + re.escape(old) + r"(?![A-Za-zÀ-ÖØ-öø-ÿ'])")
        matches = list(pattern.finditer(text, max(0, from_offset)))
        if not matches:
            return 0
        def edit(buf):
            shift = 0
            for m in matches:
                s = m.start() + shift
                e = m.end() + shift
                it1 = buf.get_iter_at_offset(s)
                it2 = buf.get_iter_at_offset(e)
                buf.delete(it1, it2)
                buf.insert(buf.get_iter_at_offset(s), new)
                shift += len(new) - len(old)
        self.execute_command("Replace All Word", edit)
        return len(matches)

    def on_check(self, *_):
        self.clear_spell_tags()
        try:
            if not self.hunspell_base_command():
                self.error("Hunspell was not found. Install hunspell and the required dictionaries, for example hunspell-it and hunspell-en-us.")
                return
            misspelled = self.hunspell_misspelled_words(self.buffer_text())
            if misspelled is None:
                self.error("Hunspell was not found.")
                return
            if not misspelled:
                self.info("No spelling issues found.")
                return

            ignored = set()
            offset = 0
            fixed = 0
            ignored_count = 0

            while True:
                active_errors = misspelled - ignored
                found = self.find_next_error(offset, active_errors)
                if not found:
                    break
                start, end, word = found
                self.select_range(start, end)
                suggestions = self.hunspell_suggestions(word)
                response, replacement = self.spelling_dialog(word, suggestions)

                if response == Gtk.ResponseType.CANCEL:
                    self.clear_spell_tags()
                    self.update_title()
                    return
                if response == 10:  # Ignore
                    ignored_count += 1
                    offset = end
                    continue
                if response == 11:  # Ignore all
                    ignored.add(word)
                    ignored_count += 1
                    offset = end
                    continue
                if response == 20:  # Replace
                    if replacement and replacement != word:
                        self.replace_buffer_range(start, end, replacement)
                        fixed += 1
                        offset = start + len(replacement)
                    else:
                        offset = end
                    continue
                if response == 21:  # Replace all
                    if replacement and replacement != word:
                        fixed += self.replace_all_word(word, replacement, start)
                        misspelled.discard(word)
                        offset = start + len(replacement)
                    else:
                        offset = end
                    continue

            self.clear_spell_tags()
            self.update_title()
            self.info(f"Spellcheck complete. Replacements: {fixed}. Ignored: {ignored_count}.")
        except Exception as e:
            self.error(str(e))

    def shortcut_rows(self):
        return SHORTCUT_ROWS

    def on_keyboard_shortcuts(self, *_):
        show_keyboard_shortcuts(self, self.shortcut_rows())

    def on_about(self, *_):
        show_about(self, VERSION, RUNTIME_ABOUT_NAME)

    def info(self, msg):
        show_info(self, msg)

    def large_info(self, title, body):
        show_large_info(self, title, body)

    def error(self, msg):
        show_error(self, msg)


if __name__ == "__main__":
    win = App()
    win.show_all()
    # Clip panel starts detached and is attached lazily on demand.
    Gtk.main()
