    def command_layer_remove_extra_spaces_text(self, text):
        # Compute Remove Extra Spaces through CommandLayer without mutating Gtk.TextBuffer.
        result = self.command_layer.dispatch(
            "writing.remove-extra-spaces",
            CommandContext(app=self, source="gui", data={"text": text}),
        )
        if result.success and isinstance(result.value, dict):
            transformed = result.value.get("text", text)
        elif result.success:
            transformed = result.value
        else:
            return text, False
        if not isinstance(transformed, str):
            return text, False
        return transformed, transformed != text

    def command_layer_join_lines_text(self, text):
        # Compute Join Lines through CommandLayer without mutating Gtk.TextBuffer.
        result = self.command_layer.dispatch(
            "writing.join-lines",
            CommandContext(app=self, source="gui", data={"text": text}),
        )
        if result.success and isinstance(result.value, dict):
            transformed = result.value.get("text", text)
        elif result.success:
            transformed = result.value
        else:
            return text, False
        if not isinstance(transformed, str):
            return text, False
        return transformed, transformed != text

    def command_layer_remove_trailing_spaces_text(self, text):
        # Compute Remove Trailing Spaces through CommandLayer without mutating Gtk.TextBuffer.
        result = self.command_layer.dispatch(
            "writing.remove-trailing-spaces",
            CommandContext(app=self, source="gui", data={"text": text}),
        )
        if result.success and isinstance(result.value, dict):
            transformed = result.value.get("text", text)
        elif result.success:
            transformed = result.value
        else:
            return text, False
        if not isinstance(transformed, str):
            return text, False
        return transformed, transformed != text


    def command_layer_title_case_text(self, text):
