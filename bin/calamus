    def ask_save(self):
        return dialog_ask_save(self, self.modified)

    def may_continue(self):
        r = self.ask_save()
        if r == "cancel":
            return False
        if r == "save":
            return self.save_file()
        return True

    def request_application_close(self, *, quit_main_loop):
        # The unsaved-document decision is authoritative.  Persist window and
        # editor settings only after the close request has been accepted.
        if not self.may_continue():
            return False
        self.save_settings()
        if quit_main_loop:
            Gtk.main_quit()
        return True

    def on_close(self, *_):
        return not self.request_application_close(quit_main_loop=False)

    def on_quit(self, *_):
        return self.request_application_close(quit_main_loop=True)

    def on_new(self, *_):
        if not self.may_continue():
            return
        self.execute_new_plan(prepare_new_plan())

    def execute_new_plan(self, plan):
        # Commit the empty document identity only after Gtk accepts the text.
        self.loading = True
        try:
            self.text.get_buffer().set_text(plan.text)
        finally:
            self.loading = False
        self.document.file_path = plan.target_path
        self.document.set_text(plan.text, modified=plan.modified)
        self.current_file = self.document.file_path
        self.modified = self.document.modified
        self.reset_undo_history()
        self.update_title()
        return True

    def on_open(self, *_):
        if not self.may_continue():
            return
        path = choose_open_file(self)
        if path:
            self.open_path(path)

    def open_path(self, path, silent=False):
        try:
            plan = prepare_open_plan(
                path,
                read_text_file(path),
                large_file=is_large_text_file(path),
            )
            return self.execute_open_plan(plan, silent=silent)
        except (OSError, UnicodeError, TypeError, ValueError) as e:
            if not silent:
                self.error(str(e))
            return False

    def execute_open_plan(self, plan, silent=False):
        # Commit editor/document identity only after Gtk accepts loaded text.
        self.loading = True
        try:
            self.text.get_buffer().set_text(plan.text)
        finally:
            self.loading = False
        self.document.file_path = plan.target_path
        self.document.set_text(plan.text, modified=False)
        self.current_file = self.document.file_path
        self.modified = self.document.modified
        self.reset_undo_history()
        self.add_recent_file(self.current_file)
        self.update_title()
        self.save_settings()
        if plan.large_file and not silent:
            self.info("Large file mode", f"This file is larger than {LARGE_FILE_BYTES // 1_000_000} MB. Undo history is limited to keep Calamus responsive.")
        return True

    def on_save(self, *_):
        self.save_file()

    def on_save_as(self, *_):
        self.save_as()

    def save_file(self):
        plan = prepare_save_plan(
            self.current_file,
            self.buffer_text(),
            trim_trailing_on_save=getattr(self, "trim_trailing_on_save", False),
        )
        if plan.requires_destination:
            return self.save_as()
        return self.execute_save_plan(plan)

    def execute_save_plan(self, plan):
        try:
            if plan.replaces_buffer_text:
                self.loading = True
                self.text.get_buffer().set_text(plan.text_to_write)
                self.loading = False
            self.document.save(plan.target_path, plan.text_to_write)
            self.current_file = self.document.file_path
            self.modified = self.document.modified
            self.add_recent_file(self.current_file)
            self.update_title()
            self.save_settings()
            return True
        except (OSError, ValueError) as e:
            self.error(str(e))
            return False

    def save_as(self):
        plan = prepare_save_as_plan(
            choose_save_file(self),
            self.buffer_text(),
            trim_trailing_on_save=getattr(self, "trim_trailing_on_save", False),
        )
        if plan is None:
            return False
        return self.execute_save_plan(plan)

    def get_cursor_offset(self):
        buf = self.text.get_buffer()
        mark = buf.get_insert()
        it = buf.get_iter_at_mark(mark)
        return it.get_offset()

    def set_cursor_offset(self, offset):
        try:
            buf = self.text.get_buffer()
            it = buf.get_iter_at_offset(max(0, int(offset)))
            buf.place_cursor(it)
            self.text.scroll_to_iter(it, 0.15, False, 0, 0)
        except Exception as exc:
            log_nonfatal("non-fatal GTK operation failed", exc)

    def on_save_session(self, *_):
        self.state.ensure_dir()
        data = {
            "version": 2,
            "mode": "future-multifile-ready",
            "files": [{
                "path": self.current_file,
                "cursor": self.get_cursor_offset(),
                "modified": self.modified
            }] if self.current_file else [],
            "current_index": 0,
            "font_size": self.font_size,
            "opacity": int(self.get_opacity()*100),
            "spell_lang": self.spell_lang,
            "inline_spell": False,
            "always_on_top": self.always_item.get_active(),
            "white_background": self.white_background,
            "dark_mode": self.dark_mode,
            "theme_name": getattr(self, "theme_name", "Classic Light"),
            "line_numbers": self.show_line_numbers,
            "width": self.get_size()[0],
            "height": self.get_size()[1],
        }
        if self.state.save_session(data):
            self.info("Session saved.")
        else:
            self.error("Could not save session.")

    def on_restore_session(self, *_):
        if not self.may_continue():
            return
        try:
            data = self.state.load_session()
            if not isinstance(data, dict):
                self.info("No valid saved session found.")
                return
            files = data.get("files") if isinstance(data.get("files"), list) else []
            current_index = clamp_int(data.get("current_index"), 0, 0, max(len(files) - 1, 0))
            item = files[current_index] if files and isinstance(files[current_index], dict) else {"path": data.get("current_file"), "cursor": 0}
            path = item.get("path")
            if not path or not os.path.exists(path):
                self.info("No saved session file found.")
                return
            self.font_size = clamp_int(data.get("font_size"), DEFAULT_FONT, MIN_FONT, MAX_FONT)
            self.font_family = data.get("font_family", self.font_family) if isinstance(data.get("font_family", self.font_family), str) else self.font_family
            self.word_wrap = bool(data.get("word_wrap", self.word_wrap))
            self.text.set_wrap_mode(Gtk.WrapMode.WORD_CHAR if self.word_wrap else Gtk.WrapMode.NONE)
            self.spell_lang = data.get("spell_lang", "it") if data.get("spell_lang", "it") in ("it", "en") else "it"
            self.inline_spell_enabled = False
            self.white_background = bool(data.get("white_background", self.white_background))
            self.dark_mode = bool(data.get("dark_mode", self.dark_mode))
            if self.white_background and self.dark_mode:
                self.dark_mode = False
            self.show_line_numbers = bool(data.get("line_numbers", self.show_line_numbers))
            self.open_path(path, silent=True)
            self.set_cursor_offset(clamp_int(item.get("cursor", 0), 0, 0, 10**9))
            self.set_opacity_value(clamp_int(data.get("opacity"), DEFAULT_OPACITY, 30, 100))
            self.always_item.set_active(bool(data.get("always_on_top", self.always_on_top)))
            self.white_item.set_active(self.white_background)
            self.dark_item.set_active(self.dark_mode)
            self.line_item.set_active(self.show_line_numbers)
            if hasattr(self, "word_wrap_item"):
                self.word_wrap_item.set_active(self.word_wrap)
            if hasattr(self, "lang_en") and hasattr(self, "lang_it"):
                self.lang_en.set_active(self.spell_lang == "en")
                self.lang_it.set_active(self.spell_lang != "en")
            self.resize(clamp_int(data.get("width"), 560, 260, 4096), clamp_int(data.get("height"), 420, 180, 4096))
            self.modified = False
            self.apply_font()
            self.update_title()
            self.save_settings()
        except FileNotFoundError:
            self.info("No saved session found.")
        except Exception as e:
            self.error(str(e))

    def on_top(self, item):
        self.set_keep_above(item.get_active())
        self.update_title()
        self.save_settings()

    def on_white_background(self, item):
        self.white_background = item.get_active()
        if self.white_background and hasattr(self, "dark_item") and self.dark_item.get_active():
            self.dark_item.set_active(False)
            self.dark_mode = False
        self.apply_font()
        self.save_settings()

    def on_dark_mode(self, item):
        self.dark_mode = item.get_active()
        if self.dark_mode and hasattr(self, "white_item") and self.white_item.get_active():
            self.white_item.set_active(False)
            self.white_background = False
        self.apply_font()
        self.save_settings()

    def on_line_numbers(self, item):
        self.show_line_numbers = item.get_active()
        self.line_numbers.set_visible(self.show_line_numbers)
        self.update_line_numbers()
        self.update_title()
        self.save_settings()

    def set_opacity_value(self, v):
        self.set_opacity(v/100.0)
        self.update_title()
        self.save_settings()

    def change_font(self, delta):
        self.font_size = max(MIN_FONT, min(MAX_FONT, self.font_size + delta))
        self.apply_font()
        self.save_settings()

    def replace_selection(self, transform, command_name="Replace Selection"):
        b = self.text.get_buffer()
        if not b.get_has_selection():
            return False
        s, e = b.get_selection_bounds()
        start = s.get_offset()
        end = e.get_offset()
        txt = b.get_text(s, e, True)
        use_layer_uppercase = (
            command_name in {"Uppercase", "Upper Case", "UPPERCASE"}
            or transform is str.upper
        )
        use_layer_lowercase = (
            command_name in {"Lowercase", "Lower Case", "LOWERCASE"}
            or transform is str.lower
        )
        if use_layer_uppercase:
            replacement, changed = self.command_layer_uppercase_text(txt)
            if not changed:
                return False
        elif use_layer_lowercase:
            replacement, changed = self.command_layer_lowercase_text(txt)
            if not changed:
                return False
        else:
            replacement = transform(txt)
        _, select = command_replace_range(self.buffer_text(), start, end, replacement)
        def edit(buf):
            it1 = buf.get_iter_at_offset(start)
            it2 = buf.get_iter_at_offset(end)
            buf.delete(it1, it2)
            buf.insert(buf.get_iter_at_offset(start), replacement)
        return self.execute_command(command_name, edit, select_range=select)

    def selected_or_all_range(self):
        b = self.text.get_buffer()
        if b.get_has_selection():
            s, e = b.get_selection_bounds()
            return s.get_offset(), e.get_offset()
        s, e = b.get_bounds()
        return s.get_offset(), e.get_offset()


    def command_layer_uppercase_text(self, text):
        # Compute uppercase text through CommandLayer without mutating Gtk.TextBuffer.
        result = self.command_layer.dispatch(
            "edit.uppercase",
            CommandContext(app=self, source="gui", data={"text": text}),
        )
        if result.success and isinstance(result.value, dict):
            transformed = result.value.get("text", text)
        elif result.success:
            transformed = result.value
        else:
            return text, False
        if not isinstance(transformed, str):
            return text, False
        return transformed, transformed != text
    def command_layer_lowercase_text(self, text):
        # Compute lowercase text through CommandLayer without mutating Gtk.TextBuffer.
        result = self.command_layer.dispatch(
            "edit.lowercase",
            CommandContext(app=self, source="gui", data={"text": text}),
        )
        if result.success and isinstance(result.value, dict):
            transformed = result.value.get("text", text)
        elif result.success:
            transformed = result.value
        else:
            return text, False
        if not isinstance(transformed, str):
            return text, False
        return transformed, transformed != text

    def command_layer_smart_typography_text(self, text):
        # Compute Smart Typography through CommandLayer without mutating Gtk.TextBuffer.
        result = self.command_layer.dispatch(
            "writing.smart-typography",
            CommandContext(app=self, source="gui", data={"text": text}),
        )
        if result.success and isinstance(result.value, dict):
