DEFAULT_OPACITY = 88
DEFAULT_FONT = 12
MIN_FONT = 8
MAX_FONT = 32
DEFAULT_WINDOW_WIDTH = 900
DEFAULT_WINDOW_HEIGHT = 650
MIN_WINDOW_WIDTH = 520
MIN_WINDOW_HEIGHT = 360
MAX_WINDOW_WIDTH = 1600
MAX_WINDOW_HEIGHT = 1000

class App(Gtk.Window):
    def __init__(self):
        super().__init__(title=APP_TITLE)
        self.state = StateManager(CONFIG_DIR)
        self.settings = self.load_settings()
        self.command_layer = CommandLayer(build_low_risk_registry())

        width = clamp_int(self.settings.get("width"), DEFAULT_WINDOW_WIDTH, MIN_WINDOW_WIDTH, MAX_WINDOW_WIDTH)
        height = clamp_int(self.settings.get("height"), DEFAULT_WINDOW_HEIGHT, MIN_WINDOW_HEIGHT, MAX_WINDOW_HEIGHT)
        self.font_size = clamp_int(self.settings.get("font_size"), DEFAULT_FONT, MIN_FONT, MAX_FONT)
        self.font_family = self.settings.get("font_family", "Monospace") if isinstance(self.settings.get("font_family", "Monospace"), str) else "Monospace"
        self.word_wrap = bool(self.settings.get("word_wrap", True))
        self.always_on_top = bool(self.settings.get("always_on_top", False))
        self.spell_lang = self.settings.get("spell_lang", "it") if isinstance(self.settings.get("spell_lang", "it"), str) else "it"
        # Inline spell-check is deliberately disabled in 1.3.0.
        # F7 now runs an external, interactive Hunspell check.
        self.inline_spell_enabled = False
        self.white_background = bool(self.settings.get("white_background", True))
        self.dark_mode = bool(self.settings.get("dark_mode", False))
        self.theme_name = self.settings.get("theme_name", "Classic Light") if isinstance(self.settings.get("theme_name", "Classic Light"), str) else "Classic Light"
        if self.white_background and self.dark_mode:
            self.dark_mode = False
        self.document = Document(file_path=self.settings.get("last_file") or None)
        self.current_file = self.document.file_path

        self.modified = self.document.modified
        self.loading = False
        self.spell_source = None
        self.word_count_source = None
        self.last_search = ""
        self.last_match = None
        self.history = TextHistory(max_steps=100)
        self.undo_snapshot_source = None
        self.restoring_undo = False
        self.search_highlight_source = None
        self.print_pages = []
        self.show_line_numbers = bool(self.settings.get("line_numbers", True))
        self.focus_mode = False
        self.current_line_highlight = False
        self.distraction_free = False
        self.bookmarks = []
        self.trim_trailing_on_save = bool(self.settings.get("trim_trailing_on_save", False))

        self.set_default_size(width, height)
        # Set only a minimum size; do not set maximum geometry hints.
        # Maximum hints and size-allocate clamps made the window fight the WM
        # and caused long pasted text/Enter-heavy documents to stretch or lock
        # the top-level window. Child scrollers must contain document growth.
        self.set_size_request(MIN_WINDOW_WIDTH, MIN_WINDOW_HEIGHT)
        self.apply_window_geometry_hints()
        self.set_resizable(True)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_keep_above(self.always_on_top)
        self.set_opacity(clamp_int(self.settings.get("opacity"), DEFAULT_OPACITY, 30, 100) / 100.0)
        self.set_icon_name(APP_ICON)

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        root.set_hexpand(True)
        root.set_vexpand(True)
        self.add(root)

        self.menubar = Gtk.MenuBar()
        root.pack_start(self.menubar, False, False, 0)
        self.build_menu()

        self.body_paned = Gtk.Paned(orientation=Gtk.Orientation.HORIZONTAL)
        self.body_paned.set_hexpand(True)
        self.body_paned.set_vexpand(True)
        root.pack_start(self.body_paned, True, True, 0)

        # Keep Gtk.TextView as the direct Gtk.ScrolledWindow child.
        # GTK's native caret/selection scrolling only works reliably in this
        # topology; the line-number gutter stays outside the scroller.
        self.editor_box, self.line_numbers, self.scroller, self.text = build_editor_widgets(self.word_wrap)
        self.body_paned.pack1(self.editor_box, True, True)
        self.text.get_buffer().connect("changed", self.on_changed)
        self.text.get_buffer().connect("notify::cursor-position", self.on_cursor_position_notify)
        self.text.connect_after("key-release-event", self.on_text_key_release)
        self.text.connect_after("move-cursor", self.on_text_move_cursor)
        self.text.connect_after("motion-notify-event", self.on_text_motion_notify)
        self.text.connect_after("button-release-event", self.on_text_button_release)
        self.apply_wrap_policy()
        self.build_clip_collection()
        # Clip Collection is attached lazily by toggle_clip_collection().
        # This avoids fragile no_show_all/show_all interactions inside Gtk.Paned.
        self.clip_panel_attached = False
        self.body_paned.set_position(max(420, int(width * 0.72)))

        self.tag = self.text.get_buffer().create_tag("misspelled", underline=Pango.Underline.ERROR)
        self.search_tag = self.text.get_buffer().create_tag("search_highlight", background="#fff59d", foreground="#000000")
        self.current_line_tag = self.text.get_buffer().create_tag("current_line", background="#eef5ff")

        self.status = Gtk.Label()
        self.status.set_xalign(0)
        self.status.set_margin_start(8)
        self.status.set_margin_end(8)
        self.status.set_margin_top(3)
        self.status.set_margin_bottom(3)
        root.pack_end(self.status, False, False, 0)

        self.css = Gtk.CssProvider()
        self.apply_font()

        self.add_shortcuts()
        self.setup_file_drop_target()
        self.connect("delete-event", self.on_close)

        if self.current_file and os.path.exists(self.current_file):
            self.open_path(self.current_file, silent=True)
        else:
            self.reset_undo_history()

        self.update_title()

    def apply_window_geometry_hints(self):
        """Apply minimum geometry only.

        Calamus must never use max-size hints or resize itself from
        size-allocate. Those policies can make the top-level window expand to
        monitor bounds after large paste/Enter-heavy documents and can prevent
        normal WM resizing from the top edge. Document growth belongs inside
        Gtk.ScrolledWindow, not in Gtk.Window geometry.
        """
        try:
            geometry = Gdk.Geometry()
            geometry.min_width = MIN_WINDOW_WIDTH
            geometry.min_height = MIN_WINDOW_HEIGHT
            self.set_geometry_hints(None, geometry, Gdk.WindowHints.MIN_SIZE)
        except Exception as exc:
            log_nonfatal("window geometry hints failed", exc)

    def apply_wrap_policy(self):
        """Make word wrap depend on the visible editor width, not virtual line width."""
        if not hasattr(self, "scroller") or not hasattr(self, "text"):
            return False
        hpolicy = Gtk.PolicyType.NEVER if getattr(self, "word_wrap", True) else Gtk.PolicyType.AUTOMATIC
        self.scroller.set_policy(hpolicy, Gtk.PolicyType.AUTOMATIC)
        self.text.set_wrap_mode(Gtk.WrapMode.WORD_CHAR if getattr(self, "word_wrap", True) else Gtk.WrapMode.NONE)
        if hasattr(self, "editor_box"):
            self.editor_box.queue_resize()
        self.text.queue_resize()
        return False

    def queue_wrap_reflow(self):
        self.apply_wrap_policy()
        if hasattr(self, "body_paned"):
            self.body_paned.queue_resize()
        GLib.idle_add(self.apply_wrap_policy)

    def on_cursor_position_notify(self, *_):
        # Do not auto-scroll on every cursor-position notification. Mouse clicks
        # produce this signal too, and forcing scroll here caused the document to
        # jump down by blocks when selecting/pointing at a word.
        self.update_current_line_highlight()

    def on_text_key_release(self, *_):
        # Keep keyboard-driven typing/navigation visible, but defer one idle tick
        # and use a tiny margin so visible clicks do not get re-centered.
        self.queue_insert_scroll(margin=0.02)
        return False

    def on_text_move_cursor(self, *_):
        self.queue_insert_scroll(margin=0.02)
        return False

    def queue_insert_scroll(self, margin=0.02):
        if not hasattr(self, "text"):
            return False
        GLib.idle_add(lambda: self.ensure_insert_visible(margin))
        return False

    def ensure_insert_visible(self, margin=0.02):
        try:
            buf = self.text.get_buffer()
            self.text.scroll_to_mark(buf.get_insert(), margin, False, 0.0, 0.0)
        except Exception as exc:
            log_nonfatal("non-fatal GTK operation failed", exc)
        return False

    def on_text_motion_notify(self, widget, event):
        # Let Gtk.TextView perform native selection autoscroll. Forcing our own
        # scroll on every pointer-motion event caused unstable jumps.
        return False

    def on_text_button_release(self, widget, event):
        return False


    def setup_file_drop_target(self):
        targets = [Gtk.TargetEntry.new("text/uri-list", 0, 0)]
        for widget in (self, self.text):
            widget.drag_dest_set(Gtk.DestDefaults.ALL, targets, Gdk.DragAction.COPY)
            widget.connect("drag-data-received", self.on_drag_data_received)

    def on_drag_data_received(self, widget, context, x, y, data, info, time):
        opened = False
        try:
            for uri in data.get_uris() if data is not None else []:
                parsed = GLib.filename_from_uri(uri)
                path = parsed[0] if parsed else None
                if path and os.path.isfile(path):
                    if self.may_continue():
                        self.open_path(path)
                        opened = True
                    break
        except Exception as e:
            self.error(str(e))
        Gtk.drag_finish(context, opened, False, time)
        return True

    def load_settings(self):
        return self.state.load_settings()

    def save_settings(self):
        self.state.ensure_dir()
        width, height = self.get_size()
        width = clamp_int(width, DEFAULT_WINDOW_WIDTH, MIN_WINDOW_WIDTH, MAX_WINDOW_WIDTH)
        height = clamp_int(height, DEFAULT_WINDOW_HEIGHT, MIN_WINDOW_HEIGHT, MAX_WINDOW_HEIGHT)
        data = {
            "width": width,
            "height": height,
            "opacity": int(self.get_opacity() * 100),
            "font_size": self.font_size,
            "font_family": self.font_family,
            "word_wrap": self.word_wrap_item.get_active() if hasattr(self, "word_wrap_item") else self.word_wrap,
            "last_file": self.current_file,
            "spell_lang": self.spell_lang,
            "inline_spell": False,
            "always_on_top": self.always_item.get_active() if hasattr(self, "always_item") else False,
            "white_background": self.white_item.get_active() if hasattr(self, "white_item") else self.white_background,
            "dark_mode": self.dark_item.get_active() if hasattr(self, "dark_item") else self.dark_mode,
            "line_numbers": self.line_item.get_active() if hasattr(self, "line_item") else self.show_line_numbers,
            "trim_trailing_on_save": self.trim_trailing_on_save_item.get_active() if hasattr(self, "trim_trailing_on_save_item") else self.trim_trailing_on_save,
        }
        self.state.save_settings(data)

    def build_menu(self):
        ui_build_menu(self)

    def top(self, label):
        return ui_top_menu(self, label)

    def item(self, menu, label, cb):
        return ui_add_item(menu, label, cb)

    def sep(self, menu):
        return ui_add_separator(menu)

    def add_shortcuts(self):
        ui_add_shortcuts(self)

    def buffer_text(self):
        b = self.text.get_buffer()
        s, e = b.get_bounds()
        current = b.get_text(s, e, True)
        # Keep the non-GTK document model synchronized without making it the
        # owner of per-keystroke TextBuffer state.
        if hasattr(self, "document"):
            self.document.text = current
        return current

    def set_buffer(self, text, *, modified=False):
        self.loading = True
        self.text.get_buffer().set_text(text)
        self.loading = False
        if hasattr(self, "document"):
            self.document.set_text(text, modified=modified)
            self.current_file = self.document.file_path
            self.modified = self.document.modified
        self.reset_undo_history()

    def reset_undo_history(self):
        text = self.buffer_text()
        self.history.reset(text)
        if self.undo_snapshot_source:
            try:
                GLib.source_remove(self.undo_snapshot_source)
            except Exception:
                pass
            self.undo_snapshot_source = None

    def schedule_undo_snapshot(self):
        if self.loading or self.restoring_undo:
            return
        if self.undo_snapshot_source:
            try:
                GLib.source_remove(self.undo_snapshot_source)
            except Exception:
                pass
        self.undo_snapshot_source = GLib.timeout_add(600, self.commit_undo_snapshot)

    def commit_undo_snapshot(self):
        self.undo_snapshot_source = None
        self.history.commit(self.buffer_text())
        return False

    def commit_pending_undo(self):
        if self.undo_snapshot_source:
            try:
                GLib.source_remove(self.undo_snapshot_source)
            except Exception:
                pass
            self.undo_snapshot_source = None
        self.commit_undo_snapshot()

    def finalize_command_edit(self, select_range=None, command_name="Edit"):
        self.commit_pending_undo()
        if select_range:
            self.select_range(*select_range)
        self.modified = True
        if hasattr(self, "document"):
            self.document.mark_modified(self.buffer_text())
        self.last_command = command_name
        self.schedule_status_update()
        self.schedule_search_highlight()
        self.update_line_numbers()
        self.update_title()

    def execute_command(self, command_name, edit_func, select_range=None):
        """Single mutation gateway for editor commands.

        Every feature-level edit must pass through this handler so GTK sees a
        grouped user action and Calamus records one coherent undo snapshot.
        File/session loading intentionally bypasses this and resets history.
        """
        self.commit_pending_undo()
        before = self.buffer_text()
        b = self.text.get_buffer()
        b.begin_user_action()
        try:
            edit_func(b)
        finally:
            b.end_user_action()
        after = self.buffer_text()
        if after != before:
            self.finalize_command_edit(select_range=select_range, command_name=command_name)
            return True
        return False

    def perform_buffer_edit(self, edit_func, select_range=None, command_name="Edit"):
        # Compatibility wrapper: all callers still route through the unified command layer.
        return self.execute_command(command_name, edit_func, select_range=select_range)

    @staticmethod
    def estimate_history_cursor(before: str, after: str) -> int:
        """Return a stable cursor offset near the edit changed by undo/redo."""
        if before == after:
            return min(len(after), 0)
        prefix = 0
        limit = min(len(before), len(after))
        while prefix < limit and before[prefix] == after[prefix]:
            prefix += 1
        before_suffix = len(before)
        after_suffix = len(after)
        while before_suffix > prefix and after_suffix > prefix and before[before_suffix - 1] == after[after_suffix - 1]:
            before_suffix -= 1
            after_suffix -= 1
        return max(0, min(prefix, len(after)))

    def set_text_from_history(self, text, cursor_offset=None):
        self.restoring_undo = True
        self.loading = True
        self.text.get_buffer().set_text(text)
        self.loading = False
        self.restoring_undo = False
        if cursor_offset is not None:
            self.set_cursor_offset(cursor_offset)
        self.modified = True
        if hasattr(self, "document"):
            self.document.mark_modified(text)
        self.schedule_status_update()
        self.schedule_search_highlight()
        self.update_line_numbers()
        self.update_title()

    def on_undo(self, *_):
        self.commit_pending_undo()
        current_text = self.buffer_text()
        text = self.history.undo(current_text)
        if text is None:
            if self.history.disabled_reason:
                self.status.set_text(self.history.disabled_reason)
            return
        self.set_text_from_history(text, self.estimate_history_cursor(current_text, text))

    def on_redo(self, *_):
        current_text = self.buffer_text()
        text = self.history.redo()
        if text is None:
            if self.history.disabled_reason:
                self.status.set_text(self.history.disabled_reason)
            return
        self.set_text_from_history(text, self.estimate_history_cursor(current_text, text))

    def on_changed(self, *_):
        if not self.loading:
            self.modified = True
            if hasattr(self, "document"):
                self.document.mark_modified(self.buffer_text())
            self.schedule_undo_snapshot()
            self.schedule_status_update()
            self.schedule_search_highlight()
            self.update_line_numbers()
            self.update_current_line_highlight()
            self.queue_insert_scroll()
            self.update_title()

    def theme_css(self):
        themes = {
            "Classic Light": ("#ffffff", "#000000", "#f5f5f5", "#555555"),
            "Soft Cream": ("#fff8e7", "#2b2418", "#f4ead2", "#6a5a3a"),
            "Sepia": ("#f3ead7", "#3b2f22", "#e4d2b2", "#6c5738"),
            "Solarized Light": ("#fdf6e3", "#586e75", "#eee8d5", "#657b83"),
            "Solarized Dark": ("#002b36", "#eee8d5", "#073642", "#93a1a1"),
            "Slate Dark": ("#20242a", "#e8e8e8", "#2d333b", "#aeb6c2"),
        }
        bg, fg, panel, muted = themes.get(getattr(self, "theme_name", "Classic Light"), themes["Classic Light"])
        return '''
        textview, textview text { background-color: %s; color: %s; }
        #line-numbers { background-color: %s; color: %s; }
        .calamus-clip-button { min-width: 44px; min-height: 20px; padding: 1px 6px; }
        #calamus-clip-title { font-weight: bold; }
        ''' % (bg, fg, panel, muted)

    def set_theme_name(self, name):
        self.theme_name = name
        if name in ("Solarized Dark", "Slate Dark"):
            self.white_background = False
            self.dark_mode = True
        else:
            self.white_background = True
            self.dark_mode = False
        self.apply_font()
        self.save_settings()
        self.update_title()

    def on_theme_selection(self, *_):
        d = Gtk.Dialog(title="Theme Selection", transient_for=self, modal=True)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Apply", Gtk.ResponseType.OK)
        box = d.get_content_area()
        box.set_spacing(6)
        box.set_margin_start(12); box.set_margin_end(12); box.set_margin_top(12); box.set_margin_bottom(12)
        names = ["Classic Light", "Soft Cream", "Sepia", "Solarized Light", "Solarized Dark", "Slate Dark"]
        group = None
        buttons = []
        for name in names:
            rb = Gtk.RadioButton.new_with_label_from_widget(group, name) if group else Gtk.RadioButton.new_with_label(None, name)
            if group is None:
                group = rb
            rb.set_active(name == getattr(self, "theme_name", "Classic Light"))
            box.pack_start(rb, False, False, 0)
            buttons.append((name, rb))
        d.show_all()
        if d.run() == Gtk.ResponseType.OK:
            for name, rb in buttons:
                if rb.get_active():
                    self.set_theme_name(name)
                    break
        d.destroy()

    def on_opacity_selection(self, *_):
        d = Gtk.Dialog(title="Opacity", transient_for=self, modal=True)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL)
        box = d.get_content_area()
        box.set_spacing(8)
        box.set_margin_start(12); box.set_margin_end(12); box.set_margin_top(12); box.set_margin_bottom(12)
        label = Gtk.Label(label="Choose a fixed opacity value:")
        label.set_xalign(0)
        box.pack_start(label, False, False, 0)
        grid = Gtk.Grid(column_spacing=6, row_spacing=6)
        vals = [30, 40, 50, 60, 70, 80, 88, 90, 100]
        for i, val in enumerate(vals):
            b = Gtk.Button(label=f"{val}%")
            b.set_size_request(58, 28)
            b.connect("clicked", lambda _w, v=val: (self.set_opacity_value(v), d.response(Gtk.ResponseType.CANCEL)))
            grid.attach(b, i % 3, i // 3, 1, 1)
        box.pack_start(grid, False, False, 0)
        d.show_all(); d.run(); d.destroy()

    def installed_hunspell_languages(self):
        names = []
        for base in ("/usr/share/hunspell", "/usr/share/myspell/dicts"):
            try:
                for fn in os.listdir(base):
                    if fn.endswith(".dic"):
                        lang = fn[:-4]
                        if lang not in names:
                            names.append(lang)
            except OSError:
                pass
        preferred = [x for x in ("it_IT", "it", "en_US", "en_GB", "en") if x in names]
        rest = sorted(x for x in names if x not in preferred)
        return preferred + rest

    def on_language_selection(self, *_):
        d = Gtk.Dialog(title="Language", transient_for=self, modal=True)
        d.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Apply", Gtk.ResponseType.OK)
        box = d.get_content_area()
        box.set_spacing(6)
        box.set_margin_start(12); box.set_margin_end(12); box.set_margin_top(12); box.set_margin_bottom(12)
        langs = self.installed_hunspell_languages() or [self.spell_lang]
        group = None
        buttons = []
        for lang in langs:
            rb = Gtk.RadioButton.new_with_label_from_widget(group, lang) if group else Gtk.RadioButton.new_with_label(None, lang)
            if group is None:
                group = rb
            rb.set_active(lang == self.spell_lang)
            box.pack_start(rb, False, False, 0)
            buttons.append((lang, rb))
        note = Gtk.Label(label="Install missing dictionaries with your system package manager, e.g. hunspell-it or hunspell-en-us.")
        note.set_xalign(0); note.set_line_wrap(True)
        box.pack_start(note, False, False, 8)
        d.show_all()
        if d.run() == Gtk.ResponseType.OK:
            for lang, rb in buttons:
                if rb.get_active():
                    self.spell_lang = lang
                    self.save_settings(); self.update_title()
                    break
        d.destroy()

    def on_system_info(self, *_):
        import platform
        dicts = ", ".join(self.installed_hunspell_languages()[:20]) or "none found"
        msg = (
            f"Calamus: {VERSION}\n"
            f"Python: {platform.python_version()}\n"
            f"GTK: {Gtk.MAJOR_VERSION}.{Gtk.MINOR_VERSION}.{Gtk.MICRO_VERSION}\n"
            f"OS: {platform.platform()}\n"
            f"Desktop: {os.environ.get('XDG_CURRENT_DESKTOP', 'unknown')}\n"
            f"Session: {os.environ.get('XDG_SESSION_TYPE', 'unknown')}\n"
            f"Config path: {self.state.config_dir}\n"
            f"Hunspell dictionaries: {dicts}"
        )
        self.large_info("System Info", msg)

    def update_title(self):
        name = self.current_file or "Untitled"
        status = "not saved" if self.modified else "saved"
        mark = " *" if self.modified else ""
        self.set_title(f"{APP_TITLE} - {name} ({status})")
        lang = self.spell_lang.upper()
        top_active = self.always_item.get_active() if hasattr(self, "always_item") else bool(self.settings.get("always_on_top", True))
        top = "top ON" if top_active else "top OFF"
        bg = "dark bg" if self.dark_mode else ("white bg" if self.white_background else "default bg")
        words, chars, lines = self.text_stats()
        ln = "lines ON" if self.show_line_numbers else "lines OFF"
        undo_note = " | undo limited" if getattr(self.history, "disabled_reason", None) else ""
        self.status.set_text(f"{name}{mark} | words {words} | chars {chars} | lines {lines} | font {self.font_size}pt | {lang} | {top} | {bg} | {ln}{undo_note}")

